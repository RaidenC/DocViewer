{
  "name": "docviewer-webapp",
  "$schema": "./node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "src/DocViewer.WebApp",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{options.outputPath}"],
      "options": {
        "command": "cd src/DocViewer.WebApp && npx vite build",
        "cwd": ".",
        "outputPath": "src/DocViewer.WebApp/dist"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd src/DocViewer.WebApp && npx vite",
        "cwd": "."
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd src/DocViewer.WebApp && npx eslint .",
        "cwd": "."
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd src/DocViewer.WebApp && npx vitest --run --passWithNoTests",
        "cwd": "."
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd src/DocViewer.WebApp && npx vite preview",
        "cwd": "."
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd src/DocViewer.WebApp && npx eslint . --fix",
        "cwd": "."
      }
    }
  }
}