{
  "name": "docviewer-webapp",
  "$schema": "./node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "src/DocViewer.WebApp",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd src/DocViewer.WebApp && npm run build",
        "cwd": ".",
        "outputPath": "src/DocViewer.WebApp/dist"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd src/DocViewer.WebApp && npm run dev",
        "cwd": "."
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd src/DocViewer.WebApp && npm run lint",
        "cwd": "."
      }
    }
  }
}